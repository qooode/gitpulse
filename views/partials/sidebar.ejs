<div class="sidebar">
    <div class="sidebar-header">
        <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
        </div>
        <h1>GitPulse</h1>
        <span class="version">v1.0</span>
    </div>

    <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= page === 'overview' ? 'active' : '' %>">
            <i data-lucide="layout-dashboard"></i>
            Overview
        </a>
        <a href="/events" class="nav-item <%= page === 'events' ? 'active' : '' %>">
            <i data-lucide="activity"></i>
            Events
        </a>
        <a href="/settings" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
            <i data-lucide="settings"></i>
            Settings
        </a>
    </nav>

    <div class="sidebar-footer">
        <form method="POST" action="/logout" style="margin:0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="nav-item"
                style="width:100%; background:none; border:none; cursor:pointer; font-family:inherit; font-size:inherit; text-align:left;">
                <i data-lucide="log-out"></i>
                Sign Out
            </button>
        </form>
    </div>
</div>