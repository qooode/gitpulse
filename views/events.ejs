<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
        <title>GitPulse — Events</title>
</head>

<body>
    <div class="app">
        <%- include('partials/sidebar') %>

            <main class="main">
                <div class="page-header">
                    <h2>Events</h2>
                    <p>All webhook events processed by GitPulse (<%= total %> total)</p>
                </div>

                <div class="card">
                    <% if (events.length===0) { %>
                        <div class="empty-state">
                            <div class="empty-icon"><i data-lucide="inbox"></i></div>
                            <h4>No events found</h4>
                            <p>Webhook events will show up here once they're received.</p>
                        </div>
                        <% } else { %>
                            <table class="events-table">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Repository</th>
                                        <th>Title</th>
                                        <th>AI Summary</th>
                                        <th>Status</th>
                                        <th>Time</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% events.forEach(function(event) { %>
                                        <tr>
                                            <td>
                                                <span class="event-type-badge <%= event.type %>">
                                                    <%= event.type %>
                                                        <%= event.action ? ` (${event.action})` : '' %>
                                                </span>
                                            </td>
                                            <td>
                                                <%= event.repo %>
                                            </td>
                                            <td class="text-truncate">
                                                <%= event.title || '—' %>
                                            </td>
                                            <td class="text-truncate">
                                                <%= event.ai_summary || '—' %>
                                            </td>
                                            <td>
                                                <% if (event.error) { %>
                                                    <span class="status-dot failed"></span>
                                                    <span title="<%= event.error %>" style="cursor: help;">Error</span>
                                                    <% } else { %>
                                                        <span
                                                            class="status-dot <%= event.discord_sent ? 'sent' : 'failed' %>"></span>
                                                        <%= event.discord_sent ? 'Sent' : 'Not sent' %>
                                                            <% } %>
                                            </td>
                                            <td class="text-muted">
                                                <%= new Date(event.created_at).toLocaleString() %>
                                            </td>
                                            <td>
                                                <button class="btn-resend" data-event-id="<%= event.id %>"
                                                    title="Resend to Discord">
                                                    <i data-lucide="refresh-cw"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>

                            <% if (totalPages> 1) { %>
                                <div class="pagination">
                                    <a href="/events?page=<%= currentPage - 1 %>"
                                        class="<%= currentPage <= 1 ? 'disabled' : '' %>">Previous</a>

                                    <% for (let i=Math.max(1, currentPage - 2); i <=Math.min(totalPages, currentPage +
                                        2); i++) { %>
                                        <% if (i===currentPage) { %>
                                            <span class="current">
                                                <%= i %>
                                            </span>
                                            <% } else { %>
                                                <a href="/events?page=<%= i %>">
                                                    <%= i %>
                                                </a>
                                                <% } %>
                                                    <% } %>

                                                        <a href="/events?page=<%= currentPage + 1 %>"
                                                            class="<%= currentPage >= totalPages ? 'disabled' : '' %>">Next</a>
                                </div>
                                <% } %>
                                    <% } %>
                </div>
            </main>
    </div>

    <script>
        lucide.createIcons();

        document.querySelectorAll('.btn-resend').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var eventId = this.dataset.eventId;
                var button = this;
                var row = button.closest('tr');

                button.disabled = true;
                button.innerHTML = '<i data-lucide="loader-2" style="animation: spin 1s linear infinite"></i>';
                lucide.createIcons({ nodes: [button] });

                try {
                    var res = await fetch('/api/events/' + eventId + '/resend', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                    });
                    var data = await res.json();

                    if (res.ok && data.success) {
                        button.innerHTML = '<i data-lucide="check"></i>';
                        lucide.createIcons({ nodes: [button] });
                        var statusCell = row.children[4];
                        if (statusCell) {
                            statusCell.innerHTML = '<span class="status-dot sent"></span>Sent';
                        }
                        setTimeout(function () {
                            button.innerHTML = '<i data-lucide="refresh-cw"></i>';
                            lucide.createIcons({ nodes: [button] });
                            button.disabled = false;
                        }, 2000);
                    } else {
                        button.innerHTML = '<i data-lucide="x"></i>';
                        lucide.createIcons({ nodes: [button] });
                        setTimeout(function () {
                            button.innerHTML = '<i data-lucide="refresh-cw"></i>';
                            lucide.createIcons({ nodes: [button] });
                            button.disabled = false;
                        }, 2000);
                    }
                } catch (err) {
                    button.innerHTML = '<i data-lucide="x"></i>';
                    lucide.createIcons({ nodes: [button] });
                    setTimeout(function () {
                        button.innerHTML = '<i data-lucide="refresh-cw"></i>';
                        lucide.createIcons({ nodes: [button] });
                        button.disabled = false;
                    }, 2000);
                }
            });
        });
    </script>

    <style>
        @keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }
    </style>
</body>

</html>